{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrabDuino",
  "version": "0.1.0",
  "identifier": "com.mehdi.crabduino",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CrabDuino",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 520,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
